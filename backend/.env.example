# Quantpilot backend env
QUANTPILOT_PROFILE=local
QUANTPILOT_API_HOST=127.0.0.1
QUANTPILOT_API_PORT=8000
QUANTPILOT_DATA_DIR=./data
QUANTPILOT_RUNS_DIR=./data/runs
QUANTPILOT_MARKET_DIR=./data/market
QUANTPILOT_LOG_LEVEL=INFO
QUANTPILOT_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# AkShare: stock_zh_a_hist 复权 — "" | qfq | hfq（默认 qfq 前复权）
QUANTPILOT_AKSHARE_ADJUST=qfq
# CSV 上传到 market 的单文件最大字节数（默认约 15MB）
# QUANTPILOT_MARKET_CSV_MAX_UPLOAD_BYTES=15728640
